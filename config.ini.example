[paths]
# 输入文件路径
input_file = data/sheet_input.xlsx

# 输出文件路径
output_file = output_transformed.xlsx

# 规则文件路径
rules_file = transform_sheet_rules.md

# 转换脚本路径
transform_file = transform_sheet.py

# 修改后的转换脚本路径
modified_file = transform_sheet_modified.py

[api]
# API 配置 - 请根据你的环境修改
# 示例1: 内网 Qwen 模型
# api_key = your_internal_api_key
# base_url = http://your-internal-server:8000/v1
# model = Qwen/Qwen3.5-27B

# 示例2: Nvidia API
# api_key = nvapi-xxxxxxxxxxxx
# base_url = https://integrate.api.nvidia.com/v1
# model = meta/llama-3.1-8b-instruct

# 示例3: OpenAI API
# api_key = sk-xxxxxxxxxxxx
# base_url = https://api.openai.com/v1
# model = gpt-4

# 请取消注释并修改上面其中一组配置
api_key = your_api_key_here
base_url = https://your-api-endpoint/v1
model = your_model_name_here

# 最大输出tokens（设置为更大的值，避免截断）
max_tokens = 80000

[settings]
# 是否启用 AI 自动修改代码
enable_ai_modify = true

# 每周四的人数参数（用于工单分配）
# 如果周四人数为6，那么当天的工单按6人平均分配
thursday_person_count = 6

[filter]
# 数据过滤规则
# 移除工单状态为以下值的行（逗号分隔）
removed_status = 已撤銷

# 移除提单所属团队为以下值的行（逗号分隔）
removed_teams = 安全內控團隊,前端網络團隊,系統平臺團隊

# 是否移除'序号'列
remove_serial_column = true
